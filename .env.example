# 后端环境变量示例。复制为 backend/.env 后按需修改。
APP_ENV=dev
DEBUG=true
API_PREFIX=/api

# 默认 SQLite，克隆即可运行。
DATABASE_URL=sqlite:///./stock_fund_platform.db
# MySQL 示例：
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/stock_fund_platform?charset=utf8mb4

SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=admin123
FIRST_USER_USERNAME=viewer
FIRST_USER_PASSWORD=viewer123

USE_SAMPLE_DATA_FALLBACK=true
CRAWL_FORCE_SAMPLE=false
CRAWL_REQUEST_TIMEOUT=25
CRAWL_MAX_RETRIES=2
CRAWL_RETRY_BASE_DELAY=0.4
CRAWL_LOOKBACK_DAYS=400
AUTO_CRAWL_ON_STARTUP=false
REALTIME_ENABLED=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
CACHE_TTL_SECONDS=30
VIEWER_EXPORT_DAILY_QUOTA=20

EXPORT_DIR=./data/exports
EXPORT_ZIP_PASSWORD=stockfund-2026
SQL_QUERY_MAX_ROWS=1000
WS_PUSH_INTERVAL=3
SCHEDULER_ENABLED=true

ALERT_WEBHOOK_URL=
ANOMALY_PCT_CHANGE_THRESHOLD=11.0
ANOMALY_VOLUME_RATIO=5.0

